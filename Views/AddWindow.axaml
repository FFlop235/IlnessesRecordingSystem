<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:IllnessesRecordingSystem.ViewModels"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="300"
        x:Class="IllnessesRecordingSystem.Views.AddWindow"
        x:DataType="viewModels:AddWindowViewModel"
        Title="Добавление новой записи"
        Width="700" Height="300">
    <StackPanel
        Orientation="Vertical"
        Spacing="10">
        <!--<Label HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="25"
               FontFamily="Arial"
               FontWeight="Bold"
               Content="Новая запись"/>-->
        
        <ComboBox ItemsSource="{Binding Employees}"
                  SelectedItem="{Binding SelectedEmployee}"
                  DisplayMemberBinding="{Binding FullName}"
                  PlaceholderText="Выбирите сотрудника..."
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>

        <ComboBox ItemsSource="{Binding IllnessTypes}"
                  SelectedItem="{Binding SelectedIllnessType}"
                  DisplayMemberBinding="{Binding Name}"
                  PlaceholderText="Выбирите тип заболевания"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
        
        <StackPanel Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <StackPanel Orientation="Vertical"
                        Spacing="1">
                <Label Content="Начальная дата:"/>
                <DatePicker SelectedDate="{Binding StartDate}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical"
                        Spacing="1">
                <Label Content="Конечная дата:"/>
                <DatePicker SelectedDate="{Binding EndDate}"/>
            </StackPanel>
        </StackPanel>
        
        <TextBox HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Width="300"
                 Height="100"
                 Watermark="Введите заметку врача..."
                 Text="{Binding DiagnosisNote}"/>
        
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="30"
                    Orientation="Horizontal">
            <Button Content="✅"
                    Command="{Binding AddRecord}"/>
            <Button Content="❌"
                    Command="{Binding Close}"/>
        </StackPanel>
    </StackPanel>
</Window>
